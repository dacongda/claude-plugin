{
  "name": "@kolmopdf/mcp-server",
  "version": "1.0.0",
  "private": false,
  "description": "KolmoPDF plugin monorepo for Claude Code, Codex CLI, and Cursor.",
  "main": "packages/mcp-server/dist/index.js",
  "types": "packages/mcp-server/dist/index.d.ts",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@9.12.0",
